# Kopieer dit bestand naar .env en pas de waarden aan
# cp .env.example .env

# Inloggegevens voor de Balans-app
BALANS_USER=admin
BALANS_PASSWORD=verander-dit

# Sessie-beveiliging (willekeurige lange string)
SESSION_SECRET=verander-dit-naar-iets-willekeurigs

# Database-wachtwoorden
DB_PASSWORD=balanspass
DB_ROOT_PASSWORD=rootpass
